# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Transmission Configuration
TRANSMISSION_URL=http://localhost:9091
TRANSMISSION_USER=your_transmission_username
TRANSMISSION_PASS=your_transmission_password

# RuTracker Configuration (optional - enables torrent search)
RUTRACKER_USERNAME=your_rutracker_username
RUTRACKER_PASSWORD=your_rutracker_password

# LLM Configuration (optional - enables smart intent parsing & filtering)
# When BASE_URL and KEY are both set, free-text searches are first parsed
# by the LLM (extract clean query + content type), then results are
# filtered to that type and sorted by seeds. OpenAI-compatible API
# (e.g. Ollama / OpenWebUI). Falls back to plain search if LLM is down.
AI_LLM_API_BASE_URL=https://your-openwebui-host/api/
AI_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model to use (gemma3:12b recommended; reasoning models like qwen3 are
# too slow due to long think chains)
AI_LLM_MODEL=gemma3:12b
# Ask the backend to keep the model resident (avoids cold reloads)
AI_LLM_KEEP_ALIVE=30m

# Webhook Configuration (optional - defaults to polling mode)
# Set WEBHOOK_MODE=true to enable webhook mode for production deployment
# Note: Webhook server runs on port 8080 and serves /update, /healthz, and /status endpoints
WEBHOOK_MODE=false
WEBHOOK_URL=https://torrent-bot.svc.fred.org.ru/update
# WEBHOOK_SECRET_TOKEN should be a random string to secure the webhook endpoint
# Generate one with: openssl rand -hex 32
WEBHOOK_SECRET_TOKEN=your_random_secret_token_here